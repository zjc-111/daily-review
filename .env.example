# Database file path (defaults to data/app.db)
DB_PATH=data/app.db

# Server config
PORT=3000
HOST=localhost
CLIENT_BASE_PATH=/

# CORS — origin allowed to call the API. Use * for dev, specific origin in prod
CORS_ORIGIN=http://localhost:5173

# ===== Optional: real LLM (for AI review) =====

# If set, the AI review endpoint will try to call a real LLM first.
# Falls back to rule engine if not set or call fails.
# Provider: volcengine (火山引擎 / 豆包)
VOLCANO_ENGINE_API_KEY=
VOLCANO_ENGINE_MODEL=doubao-1-5-pro-32k-250115
VOLCANO_ENGINE_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/chat/completions
