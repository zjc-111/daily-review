# Database file path (defaults to data/app.db)
DB_PATH=data/app.db

# Server config
PORT=3000
HOST=localhost
CLIENT_BASE_PATH=/

# CORS — origin allowed to call the API. Use * for dev, specific origin in prod
CORS_ORIGIN=http://localhost:5173

# ===== AI Review (千问 / OpenAI-compatible) =====

# Set to enable real AI review. Falls back to rule engine if not set.
AI_API_KEY=your_qwen_api_key_here
# Optional: custom endpoint / model
# LLM_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
# LLM_MODEL=qwen-plus
