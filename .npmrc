# Allow native build scripts (better-sqlite3, esbuild)
enable-pre-post-scripts=true
auto-install-peers=true

# pnpm: equivalent of --allow-build (pnpm 9+ blocks build scripts by default)
# Set to "true" to allow building native deps
ignore-scripts=false
# pnpm 10+ syntax (uncomment if on pnpm 10):
# allowedDeprecatedVersions=
# allow-build[0]=better-sqlite3
# allow-build[1]=esbuild
