{
  "name": "daily-review-local",
  "version": "2.0.0",
  "private": true,
  "description": "Daily Review — 每日复盘（Python 后端 + React 前端）",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:backend": "cd server-py && python -m uvicorn main:app --host 0.0.0.0 --port 3000 --reload",
    "dev:all": "concurrently -n be,fe \"npm run dev:backend\" \"npm run dev\"",
    "build": "vite build",
    "build:cap": "vite build && npx cap sync",
    "build:electron": "VITE_API_URL=http://localhost:3000/api vite build && electron-builder",
    "electron:dev": "concurrently -n be,fe,el \"npm run dev:backend\" \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:start": "electron .",
    "cap:sync": "vite build && npx cap sync",
    "cap:android": "vite build && npx cap sync android",
    "cap:ios": "vite build && npx cap sync ios",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "typecheck": "tsc --noEmit -p tsconfig.app.json"
  },
  "build": {
    "appId": "com.dailyreview.app",
    "productName": "Daily Review",
    "directories": {
      "output": "dist/electron"
    },
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "dist/client",
        "to": "client"
      },
      {
        "from": "server-py",
        "to": "server-py"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": "AppImage"
    },
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/sql.js/**"
    ]
  },
  "dependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/cli": "^8.4.2",
    "@capacitor/core": "^8.4.2",
    "@capacitor/ios": "^8.4.2",
    "@radix-ui/react-accordion": "^1.2.18",
    "@radix-ui/react-alert-dialog": "^1.1.21",
    "@radix-ui/react-aspect-ratio": "^1.1.13",
    "@radix-ui/react-avatar": "^1.2.4",
    "@radix-ui/react-checkbox": "^1.3.9",
    "@radix-ui/react-collapsible": "^1.1.18",
    "@radix-ui/react-context-menu": "^2.3.5",
    "@radix-ui/react-dialog": "^1.1.21",
    "@radix-ui/react-dropdown-menu": "^2.1.22",
    "@radix-ui/react-hover-card": "^1.1.21",
    "@radix-ui/react-label": "^2.1.13",
    "@radix-ui/react-menubar": "^1.1.22",
    "@radix-ui/react-navigation-menu": "^1.2.20",
    "@radix-ui/react-popover": "^1.1.21",
    "@radix-ui/react-progress": "^1.1.14",
    "@radix-ui/react-radio-group": "^1.4.5",
    "@radix-ui/react-scroll-area": "^1.2.16",
    "@radix-ui/react-select": "^2.3.5",
    "@radix-ui/react-separator": "^1.1.13",
    "@radix-ui/react-slider": "^1.4.5",
    "@radix-ui/react-slot": "^1.3.1",
    "@radix-ui/react-switch": "^1.3.5",
    "@radix-ui/react-tabs": "^1.1.19",
    "@radix-ui/react-toggle": "^1.1.16",
    "@radix-ui/react-toggle-group": "^1.1.17",
    "@radix-ui/react-tooltip": "^1.2.14",
    "@tailwindcss/vite": "^4.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.0.0",
    "lucide-react": "^0.460.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "sonner": "^1.7.0",
    "tailwind-merge": "^2.5.0",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^10.0.3",
    "electron": "^43.2.0",
    "electron-builder": "^26.15.3",
    "typescript": "~5.6.0",
    "vite": "^6.0.0",
    "wait-on": "^9.1.0"
  }
}
